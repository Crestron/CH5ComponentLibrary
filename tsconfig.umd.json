{
  "extends": "./tsconfig.base",
  "compilerOptions": {
    "module": "umd",                     /* Specify module code generation: 'none', 'commonjs', 'amd', 'system', 'umd', 'es2015', or 'ESNext'. */
    "outDir": "./compiled_bundles/umd",               /* Redirect output structure to the directory. */
    "declarationDir": "./compiled_bundles/umd"
  },
  "include": ["**/*.ts"],
  "exclude": [
    "node_modules",
    "build_bundles",
    "build_bundles_dev",
    "compiled_bundles",
    "dist",
    "docs",
    "tests"
  ]
}